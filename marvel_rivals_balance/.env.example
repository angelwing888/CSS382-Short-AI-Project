# Environment Configuration Template
# Copy this to .env and set your values

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-here-change-this

# Server Configuration
HOST=0.0.0.0
PORT=5000
WORKERS=4

# Data Configuration
DATA_FILE=balance_data.json
SCRAPER_TIMEOUT=10
SCRAPER_RATE_LIMIT=0.5

# Logging
LOG_LEVEL=INFO
